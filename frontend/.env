# VITE_API_BASE is optional. When unset, the frontend uses "/api" everywhere:
#   - In dev, Vite proxies /api -> http://localhost:5000 (see vite.config.js)
#   - In prod, Vercel routes /api/* -> the serverless function in /api
# Set this to override (e.g. http://localhost:5000/api if you're not using
# the Vite proxy, or your deployed backend URL for a split deployment).
VITE_API_BASE=/api
